# Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: secret ključ (sb_secret_...) zaobilazi RLS,
# koristi se SAMO za slanje push notifikacija svim korisnicima
SUPABASE_SECRET_KEY=

# Šifra grupe za registraciju — server-only, NE dodavati NEXT_PUBLIC prefiks
GROUP_PASSWORD=

# Web Push VAPID ključevi (npx web-push generate-vapid-keys);
# public ide u obje varijable, private samo u VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
